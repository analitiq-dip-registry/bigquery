{
  "$schema": "https://schemas.analitiq.ai/connector/latest.json",
  "kind": "database",
  "connector_id": "bigquery",
  "display_name": "Google BigQuery",
  "description": "Google BigQuery serverless data warehouse. Connects, discovers, and reads over the first-class ADBC BigQuery driver; writes land as Parquet load jobs via the BigQuery API (direct media upload, no GCS staging bucket). Authenticates with a service-account JSON key (default) or an OAuth user-credential flow; all connection state is passed via adbc.bigquery.sql.* driver options.",
  "documentation_url": "https://cloud.google.com/bigquery/docs",
  "tags": [
    "database",
    "warehouse",
    "bigquery",
    "google",
    "gcp",
    "adbc"
  ],
  "version": "1.1.0",
  "default_transport": "database",
  "transports": {
    "database": {
      "transport_type": "adbc",
      "driver": "bigquery",
      "db_kwargs": {
        "adbc.bigquery.sql.project_id": {
          "ref": "connection.parameters.project_id"
        },
        "adbc.bigquery.sql.dataset_id": {
          "ref": "connection.parameters.dataset_id"
        },
        "adbc.bigquery.sql.location": {
          "ref": "connection.parameters.location"
        },
        "adbc.bigquery.sql.auth.quota_project": {
          "ref": "connection.parameters.billing_project_id"
        },
        "adbc.bigquery.sql.auth_type": {
          "function": "lookup",
          "input": {
            "ref": "connection.parameters.auth_type"
          },
          "map": {
            "service": "adbc.bigquery.sql.auth_type.json_credential_string",
            "user": "adbc.bigquery.sql.auth_type.user_authentication"
          }
        },
        "adbc.bigquery.sql.auth_credentials": {
          "ref": "secrets.auth_json_credential"
        },
        "adbc.bigquery.sql.auth.client_id": {
          "ref": "connection.parameters.client_id"
        },
        "adbc.bigquery.sql.auth.client_secret": {
          "ref": "secrets.client_secret"
        },
        "adbc.bigquery.sql.auth.refresh_token": {
          "ref": "secrets.refresh_token"
        }
      }
    }
  },
  "auth": {
    "type": "db"
  },
  "connection_contract": {
    "inputs": {
      "project_id": {
        "source": "user",
        "phase": "pre_auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": false,
        "ui": {
          "label": "Project ID",
          "placeholder": "my-gcp-project",
          "widget": "text"
        }
      },
      "billing_project_id": {
        "source": "user",
        "phase": "pre_auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": false,
        "ui": {
          "label": "Billing Project ID",
          "placeholder": "my-billing-project",
          "widget": "text"
        }
      },
      "dataset_id": {
        "source": "user",
        "phase": "pre_auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": false,
        "ui": {
          "label": "Default Dataset",
          "placeholder": "my_dataset",
          "widget": "text"
        }
      },
      "location": {
        "source": "user",
        "phase": "pre_auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": false,
        "ui": {
          "label": "Dataset Location",
          "placeholder": "US",
          "widget": "text"
        }
      },
      "auth_type": {
        "source": "user",
        "phase": "pre_auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": true,
        "enum": [
          "service",
          "user"
        ],
        "default": "service",
        "ui": {
          "label": "Authentication Method",
          "widget": "select"
        }
      },
      "auth_json_credential": {
        "source": "user",
        "phase": "auth",
        "storage": "secrets",
        "type": "string",
        "required": false,
        "secret": true,
        "ui": {
          "label": "Service Account JSON Key",
          "placeholder": "Paste the full contents of the service-account JSON key file",
          "widget": "textarea"
        }
      },
      "client_id": {
        "source": "user",
        "phase": "auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": false,
        "ui": {
          "label": "OAuth Client ID",
          "widget": "text"
        }
      },
      "client_secret": {
        "source": "user",
        "phase": "auth",
        "storage": "secrets",
        "type": "string",
        "required": false,
        "secret": true,
        "ui": {
          "label": "OAuth Client Secret",
          "widget": "password"
        }
      },
      "refresh_token": {
        "source": "user",
        "phase": "auth",
        "storage": "secrets",
        "type": "string",
        "required": false,
        "secret": true,
        "ui": {
          "label": "OAuth Refresh Token",
          "widget": "password"
        }
      }
    }
  },
  "resource_discovery": {
    "strategy": "information_schema",
    "transport_ref": "database",
    "implementation": {
      "type": "builtin"
    },
    "produces": [
      "connection.endpoints",
      "connection.type_map"
    ],
    "triggers": {
      "list_resources": "on_activation",
      "describe_resource": "on_resource_selected"
    }
  }
}
